{
  "expo": {
    "name": "App Felix Cabrera",
    "slug": "mobile-app",
    "sdkVersion": "54.0.0",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.felixcabrera.mobileapp"
    },
    "android": {
      "package": "com.felixcabrera.mobileapp",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a tus fotos para subir imágenes.",
          "cameraPermission": "La app necesita acceso a la cámara para tomar fotos."
        }
      ]
    ]
  }
}
